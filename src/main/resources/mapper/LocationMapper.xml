<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.workspace.mapper.LocationMapper">

   <resultMap id="LocationResultMap" type="com.workspace.dto.LocationDTO">
   
		     <id property = "id" 
		          column = "id" />
   
	         <result property="locationName"
	                column="location_name"/>
	
	        <result property="country"
	                column="country"/>
   
   </resultMap>

    <select id="getAllLocations"
            resultMap="LocationResultMap">

        SELECT
            id,
            location_name,
            country
        FROM location

    </select>
    
    <select id="getLocationById"
            resultMap="LocationResultMap">

        SELECT
            id,
            location_name,
            country
        FROM location
        WHERE id = #{id}
     </select>
     
     <insert id="addLocation" useGeneratedKeys="true" keyProperty="id"> 
             
             INSERT INTO location
             (
				location_name,country 
			 )
			 VALUES 
			 (
				#{locationName},#{country}
             )
     </insert>
     
     <update id="updateLocation">
     
	     UPDATE location 
	     SET 
	     location_name = #{locationName},
	     country = #{country}
	     WHERE id = #{id} 
	     
     </update>
     
     <delete id="deleteLocation">
     
             DELETE FROM location
             WHERE id = #{id}
     </delete>
     
</mapper>