<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.workspace.mapper.SiteMapper">

   <resultMap id="SiteResultMap" type="com.workspace.dto.SiteDTO">
   
		     <id property = "id" 
		          column = "id" />
   
	         <result property="siteName"
	                column="site_name"/>
	
	        <result property="locationId"
	                column="location_id"/>
	                
            <result property="locationName"
                    column="location_name"/>
   
   </resultMap>

    <select id="getAllSites"
            resultMap="SiteResultMap">

           SELECT
			    s.id,
			    s.site_name,
			    s.location_id,
			    l.location_name
			FROM site s
			JOIN location l
			ON s.location_id = l.id

    </select>
    
      <select id="getSiteById"
            resultMap="SiteResultMap">

        SELECT
                s.id,
			    s.site_name,
			    s.location_id,
			    l.location_name
        FROM site s 
        JOIN location l
            ON s.location_id = l.id
        WHERE s.id = #{id}
     </select>
     
   <insert id="addSite" useGeneratedKeys="true" keyProperty="id"> 
             
             INSERT INTO site
             (
				site_name,location_id 
			 )
			 VALUES 
			 (
				#{siteName},#{locationId}
             )
     </insert>
     
     <update id="updateSite">
     
	     UPDATE site 
	     SET 
	     site_name = #{siteName},
	     location_id = #{locationId}
	     WHERE id = #{id} 
	     
     </update>
     
     <delete id="deleteSite">
     
             DELETE FROM site
             WHERE id = #{id}
     </delete> 
     
</mapper>