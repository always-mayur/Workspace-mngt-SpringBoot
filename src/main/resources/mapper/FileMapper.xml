			<insert id="saveFileMetadata">
			    INSERT INTO FILE_METADATA
			    (
			        original_file_name,
			        stored_file_name,
			        file_path,
			        content_type,
			        file_size
			    )
			    VALUES
			    (
			        #{originalFileName},
			        #{storedFileName},
			        #{filePath},
			        #{contentType},
			        #{fileSize}
			    )
			</insert>

     
